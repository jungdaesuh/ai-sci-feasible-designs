# Strict VMEC++ single-thread settings
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1

# AI Scientist provider/model overrides (local)
MODEL_PROVIDER=openrouter
AI_SCIENTIST_INSTRUCT_MODEL=grok-planning-short-loop
AI_SCIENTIST_THINKING_MODEL=grok-planning-full

# Optional role-level overrides for codex-native switching
# AI_SCIENTIST_ROLE_PLANNING_MODEL=codex-native-full
# AI_SCIENTIST_ROLE_LITERATURE_MODEL=codex-native-full
# AI_SCIENTIST_ROLE_ANALYSIS_MODEL=codex-native-full
